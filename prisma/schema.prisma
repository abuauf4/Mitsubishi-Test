generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("text")
  page  String @default("home")
}

model Hero {
  id        String   @id @default(cuid())
  title     String
  subtitle  String
  imagePath String   @default("/images/hero-default.jpg")
  ctaText   String   @default("Hubungi Kami")
  ctaLink   String   @default("#contact")
  page      String   @default("home")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AudienceCategory {
  id           String   @id @default(cuid())
  title        String
  description  String
  imagePath    String
  linkHref     String
  displayOrder Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Testimonial {
  id           String   @id @default(cuid())
  customerName String
  customerRole String
  content      String
  rating       Int      @default(5)
  imagePath    String   @default("")
  displayOrder Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SalesConsultant {
  id          String   @id @default(cuid())
  name        String
  phone       String
  whatsapp    String
  email       String
  title       String
  description String
  imagePath   String   @default("")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DealerLocation {
  id           String   @id @default(cuid())
  name         String
  address      String
  phone        String
  latitude     Float    @default(0)
  longitude    Float    @default(0)
  embeddingUrl String   @default("")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Vehicle {
  id           String            @id @default(cuid())
  slug         String            @unique
  name         String
  tagline      String
  category     String
  basePrice    String
  imagePath    String
  payload      String?
  specsShort   String            @default("[]")
  gallery      String?
  displayOrder Int               @default(0)
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  variants     VehicleVariant[]
  colors       VehicleColor[]
  specs        VehicleSpec[]
  features     VehicleFeature[]
}

model VehicleVariant {
  id           String          @id @default(cuid())
  vehicleId    String
  name         String
  price        String
  priceNum     Int
  transmission String
  drivetrain   String?
  imagePath    String?
  description  String?
  highlights   String          @default("[]")
  displayOrder Int             @default(0)
  vehicle      Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  colors       VehicleColor[]
}

model VehicleColor {
  id           String          @id @default(cuid())
  vehicleId    String
  variantId    String?
  name         String
  hex          String
  imagePath    String?
  displayOrder Int             @default(0)
  vehicle      Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  variant      VehicleVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model VehicleSpec {
  id           String   @id @default(cuid())
  vehicleId    String
  category     String
  items        String   @default("[]")
  displayOrder Int      @default(0)
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model VehicleFeature {
  id           String   @id @default(cuid())
  vehicleId    String
  icon         String
  title        String
  description  String
  displayOrder Int      @default(0)
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}
